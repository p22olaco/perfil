<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Perfil</title>
  <style>
    body {
      background-color: #f5f5f5; /* fundo claro */
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .perfil {
      background-color: #ffffff;
      padding: 20px;
      border-radius: 10px;
      width: 300px;
      text-align: center;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .perfil img {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
    }

    .nome {
      color: blue;
      font-size: 22px;
      margin: 10px 0;
    }

    .bio {
      color: black;
      font-size: 14px;
      margin-bottom: 15px;
    }

    .botao {
      background-color: green;
      color: white;
      padding: 10px 20px;
      border: 2px solid black;
      border-radius: 5px;
      cursor: pointer;
      font-weight: bold;
    }

    .botao:hover {
      background-color: darkgreen;
    }
  </style>
</head>
<body>

  <div class="perfil">
    <img src="https://via.placeholder.com/100" alt="Foto de perfil">
    <div class="nome">Seu Nome</div>
    <div class="bio">Esta é uma pequena bio sobre você.</div>
    <button class="botao">Seguir</button>
  </div>

</body>
</html>

